---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { CLUSTERS, CLUSTER_COLOR, DEFAULT_COLOR } from '../data/clusters';
import { newNoteUrl } from '../data/site';

const notes = await getCollection('notes');
const base = import.meta.env.BASE_URL;

// ---- 노드 ----
const nodes = notes.map((n) => ({
  id: n.id,
  name: n.data.title,
  cluster: n.data.cluster ?? 'other',
  color: CLUSTER_COLOR[n.data.cluster ?? ''] ?? DEFAULT_COLOR,
  status: n.data.status,
  url: `${base}notes/${n.id}/`,
}));

// ---- 엣지: 태그 공유 + 명시적 related ----
const ids = new Set(notes.map((n) => n.id));
const linkW = new Map<string, number>();
const addLink = (a: string, b: string, w: number) => {
  if (a === b || !ids.has(a) || !ids.has(b)) return;
  const key = [a, b].sort().join('|');
  linkW.set(key, (linkW.get(key) ?? 0) + w);
};
for (let i = 0; i < notes.length; i++) {
  const ti = new Set(notes[i].data.tags);
  for (let j = i + 1; j < notes.length; j++) {
    const shared = notes[j].data.tags.filter((t) => ti.has(t)).length;
    if (shared > 0) addLink(notes[i].id, notes[j].id, shared);
  }
}
for (const n of notes) for (const r of n.data.related) addLink(n.id, r, 2);
const links = [...linkW.entries()].map(([key, value]) => {
  const [source, target] = key.split('|');
  return { source, target, value };
});

const graphData = { nodes, links };
const clustersInUse = CLUSTERS.filter((c) => nodes.some((n) => n.cluster === c.id));
const count = nodes.length;
---

<BaseLayout title="Paper Study — 논문 지도" bare={true}>
  <div class="map-wrap">
    <div id="graph" class="map-canvas"></div>

    <div class="map-overlay map-tl">
      <a class="map-brand" href={base}>◆ PAPER&nbsp;STUDY</a>
      <h1 class="map-title">논문 지도</h1>
      <p class="map-sub">{count}편의 논문이 연관도로 이어진 네온 도시. 좌우로 돌려보고, 타워를 클릭하면 노트로 들어가요.</p>
      <div class="map-actions">
        <a class="map-listlink" href={`${base}list/`}>목록으로 보기 →</a>
        <a class="map-listlink map-newlink" href={newNoteUrl()} target="_blank" rel="noopener">+ 새 노트 쓰기</a>
      </div>
    </div>

    <div class="map-overlay map-tr map-legend">
      {
        clustersInUse.map((c) => (
          <div class="legend-row">
            <span class="legend-dot" style={`background:${c.color}; box-shadow:0 0 9px ${c.color}`} />
            {c.label}
          </div>
        ))
      }
    </div>

    <div class="map-overlay map-bl">
      <span class="map-hint">좌우 드래그 회전 · 두 손가락(우클릭) 드래그 이동 · 스크롤 확대 · 클릭 → 노트</span>
    </div>

    <noscript>
      <div class="map-overlay map-tl" style="top:auto; bottom:80px;">
        3D 지도는 자바스크립트가 필요해요. <a class="map-listlink" href={`${base}list/`}>목록으로 보기</a>
      </div>
    </noscript>

    <div id="map-err" style="display:none; position:absolute; left:22px; bottom:56px; z-index:9; max-width:82vw; color:#ff9a9a; font:12px/1.45 ui-monospace,monospace; background:rgba(30,0,10,.62); padding:8px 11px; border-radius:8px; white-space:pre-wrap;"></div>
    <script is:inline>
      window.addEventListener('error', (e) => {
        const d = document.getElementById('map-err');
        if (d) {
          d.style.display = 'block';
          d.textContent = 'ERR: ' + (e.message || (e.error && e.error.message)) +
            '  @' + ((e.filename || '').split('/').pop()) + ':' + e.lineno;
        }
      });
    </script>

    <script type="application/json" id="graph-data" set:html={JSON.stringify(graphData)}></script>
  </div>

  <script>
    import ForceGraph3D from '3d-force-graph';
    import SpriteText from 'three-spritetext';
    import * as THREE from 'three';

    const el = document.getElementById('graph');
    const dataEl = document.getElementById('graph-data');

    if (el && dataEl) {
      const data = JSON.parse(dataEl.textContent || '{"nodes":[],"links":[]}');

      // 인접 정보
      const neighbors = new Map<string, Set<string>>();
      for (const n of data.nodes) neighbors.set(n.id, new Set());
      for (const l of data.links) {
        neighbors.get(l.source)?.add(l.target);
        neighbors.get(l.target)?.add(l.source);
      }
      const idOf = (x: any) => (x && typeof x === 'object' ? x.id : x);
      const short = (s: string) => (s.length > 26 ? s.slice(0, 25) + '…' : s);
      let hovered: string | null = null;

      const Graph = new ForceGraph3D(el, { controlType: 'orbit' })
        .backgroundColor('rgba(0,0,0,0)')
        .graphData(data)
        .showNavInfo(false)
        .nodeThreeObjectExtend(false)
        .nodeThreeObject((n: any) => {
          const conns = neighbors.get(n.id)?.size || 0;
          const h = 7 + Math.min(conns, 7) * 3.4;
          const col = new THREE.Color(n.color || '#8ab4ff');
          const dim = n.status === 'todo';
          const group = new THREE.Group();
          const geo = new THREE.BoxGeometry(3.4, h, 3.4);
          const body = new THREE.Mesh(
            geo,
            new THREE.MeshBasicMaterial({ color: col, transparent: true, opacity: dim ? 0.13 : 0.2 }),
          );
          body.position.y = h / 2;
          const edges = new THREE.LineSegments(
            new THREE.EdgesGeometry(geo),
            new THREE.LineBasicMaterial({ color: col, transparent: true, opacity: dim ? 0.72 : 0.98 }),
          );
          edges.position.y = h / 2;
          group.add(body);
          group.add(edges);
          const label = new SpriteText(short(n.name));
          label.color = n.color || '#cfe6ff';
          label.textHeight = 2.4;
          (label as any).fontWeight = '600';
          label.material.depthWrite = false;
          label.center.y = 0;
          label.position.y = h + 2.6;
          group.add(label);
          return group;
        })
        .linkColor(() => 'rgba(130,200,255,0.22)')
        .linkWidth(0.5)
        .linkOpacity(0.55)
        .onNodeHover((n: any) => {
          hovered = n ? n.id : null;
          el.style.cursor = n ? 'pointer' : '';
          Graph
            .linkColor((l: any) => {
              if (!hovered) return 'rgba(130,200,255,0.22)';
              const s = idOf(l.source), t = idOf(l.target);
              return s === hovered || t === hovered ? 'rgba(190,235,255,0.9)' : 'rgba(120,120,160,0.05)';
            })
            .linkWidth((l: any) => {
              const s = idOf(l.source), t = idOf(l.target);
              return hovered && (s === hovered || t === hovered) ? 1.5 : 0.5;
            });
        })
        .onNodeClick((n: any) => {
          if (n && n.url) window.location.href = n.url;
        });

      // 컨트롤: 좌우(수평) 회전만 + 평행이동(팬) 켜기
      try {
        const controls: any = Graph.controls();
        controls.enablePan = true;
        controls.screenSpacePanning = true;
        controls.enableDamping = true;
        controls.dampingFactor = 0.12;
        const polar = 1.12; // ≈64°, 상하 틸트 고정(도시를 살짝 위에서)
        controls.minPolarAngle = polar;
        controls.maxPolarAngle = polar;
      } catch (e) { /* noop */ }

      // 바닥 네온 그리드
      try {
        const grid = new THREE.GridHelper(760, 76, 0x3ad0ff, 0x1c3c5c);
        (grid.material as any).transparent = true;
        (grid.material as any).opacity = 0.28;
        grid.position.y = -0.5;
        Graph.scene().add(grid);
      } catch (e) { /* noop */ }

      // 안개(포그) — 밤안개
      try { Graph.scene().fog = new THREE.FogExp2(0x0b0a1e, 0.0016); } catch (e) { /* noop */ }

      // 노드를 바닥 평면으로 눌러서 '도시 footprint' + 타워 위로 솟게
      try {
        Graph.d3Force('flatten', ((alpha: number) => {
          for (const n of data.nodes) n.vy = (n.vy || 0) - (n.y || 0) * 0.22 * alpha;
        }) as any);
        (Graph.d3Force('charge') as any)?.strength(-95);
      } catch (e) { /* noop */ }

      // 카메라
      try { Graph.cameraPosition({ x: 30, y: 135, z: 250 }, { x: 0, y: 12, z: 0 }, 0); } catch (e) { /* noop */ }

      // ===== 나이트시티 배경 (Edgerunners 느낌) =====
      try {
        const scene = Graph.scene();
        const neonPalette = [0x22d3ee, 0xff3df0, 0x7c5cff, 0x00ffa3, 0xffd23d, 0xff5d73, 0x33e0ff];
        const pickNeon = () => neonPalette[(Math.random() * neonPalette.length) | 0];
        const neonHex = ['#22d3ee', '#ff3df0', '#7c5cff', '#00ffa3', '#ffd23d', '#ff5d73', '#33e0ff'];
        const pickHex = () => neonHex[(Math.random() * neonHex.length) | 0];

        // 창문이 빛나는 파사드 텍스처 여러 종(공유)
        const facadeTexture = () => {
          const c = document.createElement('canvas');
          c.width = 64; c.height = 256;
          const x = c.getContext('2d')!;
          x.fillStyle = '#05060e';
          x.fillRect(0, 0, 64, 256);
          for (let r = 0; r < 42; r++) {
            for (let k = 0; k < 7; k++) {
              if (Math.random() < 0.45) continue;
              x.fillStyle = pickHex();
              x.globalAlpha = 0.35 + Math.random() * 0.6;
              x.fillRect(k * 9 + 2, r * 6 + 2, 5, 3);
            }
          }
          x.globalAlpha = 1;
          const t = new THREE.CanvasTexture(c);
          t.magFilter = THREE.NearestFilter;
          return t;
        };
        const facadeMats = Array.from({ length: 6 }, () => new THREE.MeshBasicMaterial({ map: facadeTexture() }));

        // 예시: 건물 1~2채만 배치해서 룩 확인 (맘에 들면 전체 도시로 확장)
        const makeBuilding = (x: number, z: number, w: number, d: number, h: number) => {
          const geo = new THREE.BoxGeometry(w, h, d);
          const mesh = new THREE.Mesh(geo, facadeMats[(Math.random() * facadeMats.length) | 0]);
          mesh.position.set(x, h / 2 - 2, z);
          scene.add(mesh);
          const edge = new THREE.LineSegments(
            new THREE.EdgesGeometry(geo),
            new THREE.LineBasicMaterial({ color: pickNeon(), transparent: true, opacity: 0.5 }),
          );
          edge.position.copy(mesh.position);
          scene.add(edge);
        };
        makeBuilding(130, 70, 26, 26, 150);
        makeBuilding(-120, -55, 22, 30, 112);
      } catch (e) { console.warn('city skipped', e); }

      // 블룸(네온 발광)
      import('three/examples/jsm/postprocessing/UnrealBloomPass.js')
        .then(({ UnrealBloomPass }) => {
          try {
            const bloom = new UnrealBloomPass(
              new THREE.Vector2(el.clientWidth, el.clientHeight),
              1.55, 0.9, 0.0,
            );
            Graph.postProcessingComposer().addPass(bloom);
          } catch (e) { console.warn('bloom skipped', e); }
        })
        .catch(() => { /* 블룸 없어도 동작 */ });

      // 리사이즈
      const resize = () => { Graph.width(el.clientWidth); Graph.height(el.clientHeight); };
      resize();
      window.addEventListener('resize', resize);
    }
  </script>
</BaseLayout>
