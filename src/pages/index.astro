---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { buildClusterColors, DEFAULT_COLOR } from '../data/clusters';
import { writeNewUrl } from '../data/site';

const notes = await getCollection('notes');
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const clusterColors = buildClusterColors(notes.map((n) => n.data.cluster));

const nodes = notes.map((n) => ({
  id: n.id,
  name: n.data.title,
  cluster: n.data.cluster ?? 'other',
  color: clusterColors[n.data.cluster ?? ''] ?? DEFAULT_COLOR,
  status: n.data.status,
  url: `${base}notes/${n.id}/`,
}));

const ids = new Set(notes.map((n) => n.id));
const linkW = new Map<string, number>();
const addLink = (a: string, b: string, w: number) => {
  if (a === b || !ids.has(a) || !ids.has(b)) return;
  const key = [a, b].sort().join('|');
  linkW.set(key, (linkW.get(key) ?? 0) + w);
};
for (let i = 0; i < notes.length; i++) {
  const ti = new Set(notes[i].data.tags);
  for (let j = i + 1; j < notes.length; j++) {
    const shared = notes[j].data.tags.filter((t) => ti.has(t)).length;
    if (shared > 0) addLink(notes[i].id, notes[j].id, shared);
  }
}
for (const n of notes) for (const r of n.data.related) addLink(n.id, r, 2);
const links = [...linkW.entries()].map(([key, value]) => {
  const [source, target] = key.split('|');
  return { source, target, value };
});

const graphData = { nodes, links };
const clustersInUse = Object.entries(clusterColors).map(([id, color]) => ({ id, label: id, color }));
const count = nodes.length;
---

<BaseLayout title="Paper Study — 논문 지도" bare={true}>
  <div class="map-wrap">
    <div id="graph" class="map-canvas"></div>
    <div class="map-vignette"></div>

    <div class="map-overlay map-tl">
      <a class="map-brand" href={base}>◆ PAPER&nbsp;STUDY</a>
      <h1 class="map-title">논문 지도</h1>
      <p class="map-sub">{count}편의 논문이 네온 타워로. 좌우로 돌려보고, 타워를 클릭하면 노트로.</p>
      <div class="map-actions">
        <a class="map-listlink" href={`${base}list/`}>목록으로 보기 →</a>
        <a class="map-listlink map-newlink" href={writeNewUrl()}>+ 새 노트 쓰기</a>
      </div>
    </div>

    <div class="map-overlay map-tr map-legend">
      {
        clustersInUse.map((c) => (
          <div class="legend-row">
            <span class="legend-dot" style={`background:${c.color}; box-shadow:0 0 9px ${c.color}`} />
            {c.label}
          </div>
        ))
      }
    </div>

    <div class="map-overlay map-bl">
      <span class="map-hint">좌우 드래그 회전 · 두 손가락(우클릭) 드래그 이동 · 스크롤 확대 · 클릭 → 노트</span>
    </div>

    <noscript>
      <div class="map-overlay map-tl" style="top:auto; bottom:80px;">
        3D 지도는 자바스크립트가 필요해요. <a class="map-listlink" href={`${base}list/`}>목록으로 보기</a>
      </div>
    </noscript>

    <div id="map-err" style="display:none; position:absolute; left:22px; bottom:56px; z-index:9; max-width:82vw; color:#ff9a9a; font:12px/1.45 ui-monospace,monospace; background:rgba(30,0,10,.62); padding:8px 11px; border-radius:8px; white-space:pre-wrap;"></div>
    <script is:inline>
      window.addEventListener('error', (e) => {
        const d = document.getElementById('map-err');
        if (d) {
          d.style.display = 'block';
          d.textContent = 'ERR: ' + (e.message || (e.error && e.error.message)) +
            '  @' + ((e.filename || '').split('/').pop()) + ':' + e.lineno;
        }
      });
    </script>

    <script type="application/json" id="graph-data" set:html={JSON.stringify(graphData)}></script>
  </div>

  <script>
    import ForceGraph3D from '3d-force-graph';
    import SpriteText from 'three-spritetext';
    import * as THREE from 'three';

    // ---- 공유: 네온 팔레트 + 창문 파사드 텍스처 ----
    const NEON = [0x22d3ee, 0xff3df0, 0x7c5cff, 0x00ffa3, 0xffd23d, 0xff5d73, 0x33e0ff];
    const NEON_HEX = ['#22d3ee', '#ff3df0', '#7c5cff', '#00ffa3', '#ffd23d', '#ff5d73', '#33e0ff'];
    const pickNeon = () => NEON[(Math.random() * NEON.length) | 0];
    const pickHex = () => NEON_HEX[(Math.random() * NEON_HEX.length) | 0];
    const makeFacade = (mono: boolean) => {
      const c = document.createElement('canvas');
      c.width = 64; c.height = 256;
      const x = c.getContext('2d')!;
      x.fillStyle = '#04040c';
      x.fillRect(0, 0, 64, 256);
      for (let r = 0; r < 42; r++) {
        for (let k = 0; k < 7; k++) {
          if (Math.random() < 0.58) continue;
          x.fillStyle = mono ? '#ffffff' : pickHex();
          x.globalAlpha = 0.28 + Math.random() * 0.5;
          x.fillRect(k * 9 + 2, r * 6 + 2, 5, 3);
        }
      }
      x.globalAlpha = 1;
      const t = new THREE.CanvasTexture(c);
      t.magFilter = THREE.NearestFilter;
      return t;
    };
    const cityMats = Array.from({ length: 6 }, () => new THREE.MeshBasicMaterial({ map: makeFacade(false) }));
    const noteFacade = makeFacade(true); // 흰 창문 → 클러스터 색으로 tint

    const el = document.getElementById('graph');
    const dataEl = document.getElementById('graph-data');

    if (el && dataEl) {
      const data = JSON.parse(dataEl.textContent || '{"nodes":[],"links":[]}');

      const neighbors = new Map<string, Set<string>>();
      for (const n of data.nodes) neighbors.set(n.id, new Set());
      for (const l of data.links) {
        neighbors.get(l.source)?.add(l.target);
        neighbors.get(l.target)?.add(l.source);
      }
      const idOf = (x: any) => (x && typeof x === 'object' ? x.id : x);
      const short = (s: string) => (s.length > 26 ? s.slice(0, 25) + '…' : s);
      let hovered: string | null = null;

      const Graph = new ForceGraph3D(el, { controlType: 'orbit' })
        .backgroundColor('rgba(0,0,0,0)')
        .graphData(data)
        .showNavInfo(false)
        .enableNodeDrag(false)
        .nodeThreeObjectExtend(false)
        .nodeThreeObject((n: any) => {
          // 노트 = 클러스터 색으로 빛나는 창문 타워 (주인공)
          const conns = neighbors.get(n.id)?.size || 0;
          const h = 16 + Math.min(conns, 8) * 5;
          const w = 7;
          const col = new THREE.Color(n.color || '#8ab4ff');
          const group = new THREE.Group();
          const geo = new THREE.BoxGeometry(w, h, w);
          const body = new THREE.Mesh(
            geo,
            new THREE.MeshBasicMaterial({ map: noteFacade, color: col, transparent: true, opacity: 0.95 }),
          );
          body.position.y = h / 2;
          group.add(body);
          const edge = new THREE.LineSegments(
            new THREE.EdgesGeometry(geo),
            new THREE.LineBasicMaterial({ color: col, transparent: true, opacity: 1 }),
          );
          edge.position.y = h / 2;
          group.add(edge);
          const cap = new THREE.Mesh(new THREE.BoxGeometry(w * 0.55, 1.6, w * 0.55), new THREE.MeshBasicMaterial({ color: col }));
          cap.position.y = h + 1;
          group.add(cap);
          const ring = new THREE.Mesh(
            new THREE.RingGeometry(w * 1.0, w * 1.7, 28),
            new THREE.MeshBasicMaterial({ color: col, transparent: true, opacity: 0.2, side: THREE.DoubleSide }),
          );
          ring.rotation.x = -Math.PI / 2;
          ring.position.y = 0.3;
          group.add(ring);
          const label = new SpriteText(short(n.name));
          label.color = n.color || '#cfe6ff';
          label.textHeight = 3;
          (label as any).fontWeight = '700';
          label.material.depthWrite = false;
          label.center.y = 0;
          label.position.y = h + 4;
          group.add(label);
          return group;
        })
        .linkColor(() => 'rgba(140,205,255,0.28)')
        .linkWidth(0.7)
        .linkOpacity(0.6)
        .onNodeHover((n: any) => {
          hovered = n ? n.id : null;
          el.style.cursor = n ? 'pointer' : '';
          Graph
            .linkColor((l: any) => {
              if (!hovered) return 'rgba(140,205,255,0.28)';
              const s = idOf(l.source), t = idOf(l.target);
              return s === hovered || t === hovered ? 'rgba(200,240,255,0.95)' : 'rgba(120,120,160,0.06)';
            })
            .linkWidth((l: any) => {
              const s = idOf(l.source), t = idOf(l.target);
              return hovered && (s === hovered || t === hovered) ? 1.8 : 0.7;
            });
        })
        .onNodeClick((n: any) => {
          if (n && n.url) window.location.href = n.url;
        });

      try {
        const controls: any = Graph.controls();
        controls.enablePan = true;
        controls.screenSpacePanning = true;
        controls.enableDamping = true;
        controls.dampingFactor = 0.12;
        const polar = 1.32;
        controls.minPolarAngle = polar;
        controls.maxPolarAngle = polar;
      } catch (e) { /* noop */ }

      try { Graph.scene().fog = new THREE.FogExp2(0x0a0a1e, 0.0016); } catch (e) { /* noop */ }

      try {
        Graph.d3Force('flatten', ((alpha: number) => {
          for (const n of data.nodes) n.vy = (n.vy || 0) - (n.y || 0) * 0.22 * alpha;
        }) as any);
        (Graph.d3Force('charge') as any)?.strength(-110);
      } catch (e) { /* noop */ }

      try { Graph.cameraPosition({ x: 12, y: 72, z: 210 }, { x: 0, y: 20, z: -20 }, 0); } catch (e) { /* noop */ }

      // ===== 나이트시티: 젖은 거리 + 도로 + 강 + 반사 + 모션 =====
      const beacons: any[] = [];
      let dust: any = null;
      let river: any = null;
      try {
        const scene = Graph.scene();

        // 젖은 거리 바닥 (반투명 어두움 — 아래 반사가 비침)
        const wet = new THREE.Mesh(
          new THREE.PlaneGeometry(3400, 3400),
          new THREE.MeshBasicMaterial({ color: 0x05060f, transparent: true, opacity: 0.72 }),
        );
        wet.rotation.x = -Math.PI / 2;
        scene.add(wet);

        // 네온 도로 그리드 (거리)
        const roads = new THREE.Group();
        const roadMat = new THREE.MeshBasicMaterial({ color: 0x2ad0ff, transparent: true, opacity: 0.32, blending: THREE.AdditiveBlending, depthWrite: false });
        for (let i = -5; i <= 5; i++) {
          const rx = new THREE.Mesh(new THREE.PlaneGeometry(2000, 2.2), roadMat);
          rx.rotation.x = -Math.PI / 2; rx.position.set(0, 0.08, i * 150); roads.add(rx);
          const rz = new THREE.Mesh(new THREE.PlaneGeometry(2.2, 2000), roadMat);
          rz.rotation.x = -Math.PI / 2; rz.position.set(i * 150, 0.08, 0); roads.add(rz);
        }
        scene.add(roads);

        // 강(하천) — 앞쪽, 도시가 물에 비침
        river = new THREE.Mesh(
          new THREE.PlaneGeometry(2000, 120),
          new THREE.MeshBasicMaterial({ color: 0x0a2740, transparent: true, opacity: 0.5, depthWrite: false }),
        );
        river.rotation.x = -Math.PI / 2;
        river.position.set(0, 0.05, 150);
        scene.add(river);
        const bankMat = new THREE.MeshBasicMaterial({ color: 0x33e0ff, transparent: true, opacity: 0.55, blending: THREE.AdditiveBlending, depthWrite: false });
        for (const zz of [90, 210]) {
          const bank = new THREE.Mesh(new THREE.PlaneGeometry(2000, 2.6), bankMat);
          bank.rotation.x = -Math.PI / 2; bank.position.set(0, 0.1, zz); scene.add(bank);
        }
        // 다리
        const bridgeMat = new THREE.MeshBasicMaterial({ color: 0x140f26 });
        const bridgeEdgeMat = new THREE.LineBasicMaterial({ color: 0xff5db0, transparent: true, opacity: 0.75 });
        for (const bx of [-130, 150]) {
          const bg = new THREE.BoxGeometry(15, 5, 140);
          const b = new THREE.Mesh(bg, bridgeMat); b.position.set(bx, 4, 150); scene.add(b);
          const be = new THREE.LineSegments(new THREE.EdgesGeometry(bg), bridgeEdgeMat); be.position.copy(b.position); scene.add(be);
        }

        // 도시 (가운데 플라자는 비우고 바깥으로 높아짐)
        const city = new THREE.Group();
        for (let i = 0; i < 280; i++) {
          const ang = Math.random() * Math.PI * 2;
          const rad = 160 + Math.random() * 640;
          const t = (rad - 160) / 640;
          const w = 8 + Math.random() * 20;
          const d = 8 + Math.random() * 20;
          const hh = 18 + t * 320 * (0.5 + Math.random() * 0.8);
          const geo = new THREE.BoxGeometry(w, hh, d);
          const mesh = new THREE.Mesh(geo, cityMats[(Math.random() * cityMats.length) | 0]);
          mesh.position.set(Math.cos(ang) * rad, hh / 2, Math.sin(ang) * rad);
          city.add(mesh);
          if (Math.random() < 0.38) {
            const edge = new THREE.LineSegments(new THREE.EdgesGeometry(geo),
              new THREE.LineBasicMaterial({ color: pickNeon(), transparent: true, opacity: 0.26 }));
            edge.position.copy(mesh.position); city.add(edge);
          }
          if (hh > 150 && Math.random() < 0.4) {
            const beacon = new THREE.Mesh(new THREE.SphereGeometry(1.4, 8, 8),
              new THREE.MeshBasicMaterial({ color: 0xff3355, transparent: true, opacity: 1 }));
            beacon.position.set(mesh.position.x, hh + 1.5, mesh.position.z);
            beacon.userData.phase = Math.random() * 6.28;
            scene.add(beacon); beacons.push(beacon);
          }
        }
        scene.add(city);

        // 반사: 도시를 아래로 미러링(어둡게)
        const refl = city.clone(true);
        refl.scale.y = -1;
        refl.position.y = -0.05;
        refl.traverse((o: any) => {
          if (o.material) {
            o.material = o.material.clone();
            o.material.transparent = true;
            o.material.opacity = (o.material.opacity ?? 1) * 0.3;
            o.material.depthWrite = false;
          }
        });
        scene.add(refl);

        // 흐르는 네온 먼지
        const PC = 650;
        const pos = new Float32Array(PC * 3);
        for (let i = 0; i < PC; i++) {
          pos[i * 3] = (Math.random() - 0.5) * 1700;
          pos[i * 3 + 1] = Math.random() * 520;
          pos[i * 3 + 2] = (Math.random() - 0.5) * 1700;
        }
        const pg = new THREE.BufferGeometry();
        pg.setAttribute('position', new THREE.BufferAttribute(pos, 3));
        dust = new THREE.Points(pg, new THREE.PointsMaterial({ color: 0x8fd8ff, size: 1.4, transparent: true, opacity: 0.42, depthWrite: false }));
        scene.add(dust);
      } catch (e) { console.warn('city skipped', e); }

      // 모션 (경광등 깜빡임 + 먼지 흐름 + 강 물결)
      let _t = 0;
      const animate = () => {
        _t += 0.016;
        for (const b of beacons) b.material.opacity = 0.18 + 0.82 * Math.abs(Math.sin(_t * 2.2 + b.userData.phase));
        if (dust) dust.rotation.y = _t * 0.008;
        if (river) river.material.opacity = 0.44 + 0.08 * Math.sin(_t * 1.3);
        requestAnimationFrame(animate);
      };
      requestAnimationFrame(animate);

      import('three/examples/jsm/postprocessing/UnrealBloomPass.js')
        .then(({ UnrealBloomPass }) => {
          try {
            const bloom = new UnrealBloomPass(new THREE.Vector2(el.clientWidth, el.clientHeight), 1.15, 0.85, 0.5);
            Graph.postProcessingComposer().addPass(bloom);
          } catch (e) { console.warn('bloom skipped', e); }
        })
        .catch(() => { /* noop */ });

      const resize = () => { Graph.width(el.clientWidth); Graph.height(el.clientHeight); };
      resize();
      window.addEventListener('resize', resize);
    }
  </script>
</BaseLayout>
